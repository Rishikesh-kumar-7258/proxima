# Copy to .env and fill from Supabase → Project Settings → API Keys.
# Only VITE_* vars reach the browser; the publishable key is safe to expose (RLS protects data).
VITE_SUPABASE_URL=https://your-project.supabase.co

# New projects: use the Publishable key (starts with sb_publishable_...).
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Older projects only: the legacy anon JWT still works as a fallback. Leave unset if using the line above.
# VITE_SUPABASE_ANON_KEY=
